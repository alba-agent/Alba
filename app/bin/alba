/**
 * alba — ALBA desktop app launcher
 * Starts the server and opens the dashboard
 */

import { spawn } from "node:child_process";
import { existsSync, readFileSync, writeFileSync, mkdirSync } from "node:fs";
import { join } from "node:path";
import { homedir } from "node:os";

const ALBA_HOME = join(homedir(), ".alba");
const PID_FILE = join(ALBA_HOME, "server.pid");
const PORT = 3001;

mkdirSync(ALBA_HOME, { recursive: true });

// Check if already running
if (existsSync(PID_FILE)) {
  try {
    const pid = parseInt(readFileSync(PID_FILE, "utf-8").trim());
    process.kill(pid, 0);
    console.log("ALBA is already running. Opening dashboard...");
    spawn("open", [`http://localhost:${PORT}`], { stdio: "ignore" });
    process.exit(0);
  } catch { /* not running */ }
}

// Start server
const serverDir = join(import.meta.dirname, "..", "server");
const child = spawn("node", ["server.js"], {
  cwd: serverDir,
  env: { ...process.env, ALBA_HOME },
  stdio: ["ignore", "pipe", "pipe"],
  detached: true,
});

child.unref();
writeFileSync(PID_FILE, String(child.pid), "utf-8");

console.log(`ALBA server starting on port ${PORT}...`);

// Wait for server
let ready = false;
for (let i = 0; i < 30; i++) {
  await new Promise(r => setTimeout(r, 1000));
  try {
    const res = await fetch(`http://localhost:${PORT}/api/status`);
    if (res.ok) { ready = true; break; }
  } catch { /* not ready */ }
}

if (ready) {
  console.log(`ALBA started. Dashboard: http://localhost:${PORT}`);
  spawn("open", [`http://localhost:${PORT}`], { stdio: "ignore" });
} else {
  console.log(`ALBA server may still be starting. Check: http://localhost:${PORT}`);
}

process.on("SIGTERM", () => {
  try { process.kill(parseInt(readFileSync(PID_FILE, "utf-8").trim())); } catch {}
  process.exit(0);
});
