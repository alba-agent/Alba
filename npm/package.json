{
  "name": "@albalink/agent",
  "version": "1.0.1",
  "description": "ALBA — standalone AI agent engine. Runs locally, extensible, zero cloud dependency.",
  "author": "ALBA",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "albacli": "bin/albacli",
    "alba-mcp": "bin/alba-mcp",
    "albalink": "bin/albacli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "tsx": "^4.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.29",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "ai",
    "agent",
    "local",
    "assistant",
    "terminal",
    "cli",
    "alba",
    "swarm",
    "extensible"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "!dist/**/*.map",
    "!dist/**/*.test.*"
  ]
}
